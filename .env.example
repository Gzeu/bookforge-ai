# ============================================================
# BookForge AI — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- NovelClaw Connection ---
NOVELCLAW_BASE_URL=http://127.0.0.1:8012
NOVELCLAW_API_KEY=change-this-agent-api-key

# --- AI Providers (at least one required) ---
DEEPSEEK_API_KEY=sk-your-deepseek-key-here
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# --- Default Provider ---
# Options: deepseek | openai | anthropic | local_llm
DEFAULT_PROVIDER=deepseek

# --- Output Directories ---
MANUSCRIPTS_DIR=./manuscripts
EPUB_OUTPUT_DIR=./epub_output
COVERS_DIR=./covers

# --- Amazon KDP (optional — only needed for auto-upload) ---
KDP_EMAIL=your@email.com
KDP_PASSWORD=your_kdp_password
KDP_HEADLESS=false
