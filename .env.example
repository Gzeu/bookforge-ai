# ============================================================
# BookForge AI — Environment Configuration
# Copy this file to .env and fill in your values
# ============================================================

# --- NovelClaw Connection ---
NOVELCLAW_BASE_URL=http://127.0.0.1:8012
NOVELCLAW_API_KEY=change-this-agent-api-key

# --- AI Providers (at least one required) ---

# FREE providers (recommended to start)
MISTRAL_API_KEY=your-mistral-api-key-here      # free tier: mistral.ai
CEREBRAS_API_KEY=your-cerebras-api-key-here    # free tier: cerebras.ai

# Paid providers (optional)
DEEPSEEK_API_KEY=sk-your-deepseek-key-here     # ~$0.007/book
OPENAI_API_KEY=sk-your-openai-key-here
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key-here

# Local (free, needs Ollama running)
# LOCAL_LLM_URL=http://localhost:11434

# --- Default Provider ---
# Options: mistral | cerebras | deepseek | openai | anthropic | local_llm
DEFAULT_PROVIDER=mistral

# --- Output Directories ---
MANUSCRIPTS_DIR=./manuscripts
EPUB_OUTPUT_DIR=./epub_output
COVERS_DIR=./covers

# --- Amazon KDP (optional — only needed for auto-upload) ---
KDP_EMAIL=your@email.com
KDP_PASSWORD=your_kdp_password
KDP_HEADLESS=false

# --- Email Delivery (optional) ---
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASSWORD=your_app_password
EMAIL_FROM=BookForge AI <your@gmail.com>

# --- Webhooks (optional) ---
DISCORD_WEBHOOK_URL=
